generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Pipeline Enums ──────────────────────────────────────────────

enum PipelineStage {
  FETCHED
  CLASSIFIED
  SOURCE_READ
  DEDUPED
  VERIFIED
  CONTENT_GENERATED
  QA_PASSED
  PUBLISHED
  REJECTED
  DUPLICATE
  FAILED
}

enum ArticleType {
  PRODUCT_LAUNCH
  BUSINESS
  SECURITY
  STATEMENT
  DEEP_TECH
}

// ─── Pipeline Articles (Agent's internal tracking table) ─────────

model PipelineArticle {
  id                  String         @id @default(cuid())
  sourceUrl           String         @unique @map("source_url")
  source              String
  rawTitle            String         @map("raw_title")
  rawDescription      String?        @map("raw_description")
  imageUrl            String?        @map("image_url")

  // Classification
  stage               PipelineStage  @default(FETCHED)
  articleType         ArticleType?   @map("article_type")
  qualityScore        Int?           @map("quality_score")
  relevanceScore      Int?           @map("relevance_score")
  trendingScore       Int?           @map("trending_score")
  classificationReason String?       @map("classification_reason")
  classifiedAt        DateTime?      @map("classified_at")
  classifiedByModel   String?        @map("classified_by_model")
  suggestedTags       String?        @map("suggested_tags")

  // Source reading (Phase 2)
  fullArticleText     String?        @map("full_article_text") @db.Text
  sourceReadAt        DateTime?      @map("source_read_at")
  sourceReadSuccess   Boolean?       @map("source_read_success")

  // Deduplication (Phase 2)
  isDuplicate         Boolean?       @map("is_duplicate")
  duplicateOfId       String?        @map("duplicate_of_id")
  deduplicationReason String?        @map("deduplication_reason")
  deduplicatedAt      DateTime?      @map("deduplicated_at")

  // Verification (Phase 2)
  verificationScore   Int?           @map("verification_score")
  verificationNotes   String?        @map("verification_notes")
  verifiedAt          DateTime?      @map("verified_at")
  verifiedByModel     String?        @map("verified_by_model")

  // Content generation
  generatedHeadline   String?        @map("generated_headline")
  generatedSummary    String?        @map("generated_summary") @db.Text
  generatedDetail     String?        @map("generated_detail") @db.Text
  generatedWhatsNext  String?        @map("generated_whats_next") @db.Text
  generatedBuildOnThis String?       @map("generated_build_on_this") @db.Text
  generatedAt         DateTime?      @map("generated_at")
  generatedByModel    String?        @map("generated_by_model")

  // QA (Phase 2)
  qaScore             Int?           @map("qa_score")
  qaNotes             String?        @map("qa_notes")
  qaPassedAt          DateTime?      @map("qa_passed_at")
  qaReviewedByModel   String?        @map("qa_reviewed_by_model")

  // Publishing
  publishedNewsId     String?        @map("published_news_id")
  publishedAt         DateTime?      @map("published_at")

  // Failure tracking
  failedAt            DateTime?      @map("failed_at")
  failureReason       String?        @map("failure_reason")
  retryCount          Int            @default(0) @map("retry_count")
  lastRetryAt         DateTime?      @map("last_retry_at")

  // Timestamps
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@index([stage, updatedAt])
  @@map("pipeline_articles")
}

// ─── Existing Techie Shorts Tables (READ/WRITE by agent) ─────────

model News {
  id              String    @id @default(cuid())
  title           String
  summary         String
  detailContent   String?   @map("detail_content") @db.Text
  futureImpact    String?   @map("future_impact") @db.Text
  buildOnThis     String?   @map("build_on_this") @db.Text
  sourceUrl       String    @unique @map("source_url")
  imageUrl        String?   @map("image_url")
  source          String?
  isActive        Boolean   @default(true) @map("is_active")
  likeCount       Int       @default(0) @map("like_count")
  dislikeCount    Int       @default(0) @map("dislike_count")
  viewCount       Int       @default(0) @map("view_count")
  trendingScore   Int?      @map("trending_score")
  qualityScore    Int?      @map("quality_score")
  relevanceScore  Int?      @map("relevance_score")
  summaryHi       String?   @map("summary_hi")
  summaryHinglish String?   @map("summary_hinglish")
  audioUrlEn      String?   @map("audio_url_en")
  audioUrlHi      String?   @map("audio_url_hi")
  audioUrlHinglish String?  @map("audio_url_hinglish")
  audioDataEn     String?   @map("audio_data_en") @db.Text
  audioDataHi     String?   @map("audio_data_hi") @db.Text
  audioDataHinglish String? @map("audio_data_hinglish") @db.Text
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  newsTags        NewsTag[]

  @@map("news")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  newsTags  NewsTag[]

  @@map("tags")
}

model NewsTag {
  id     String @id @default(cuid())
  newsId String @map("news_id")
  tagId  String @map("tag_id")

  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([newsId, tagId])
  @@map("news_tags")
}
